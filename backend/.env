NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/ignite
JWT_ADMIN_SECRET=YOUR_VERY_STRONG_ADMIN_SECRET_KEY_HERE
JWT_USER_SECRET=YOUR_DIFFERENT_STRONG_USER_SECRET_KEY_HERE

# Gmail SMTP settings (using app password)
SMTP_USER=YOUR_MAIL_ID
SMTP_PASS=YOUR_APP_PASSWORD

# Optional: leave these unset so code defaults to Gmail
# SMTP_HOST and SMTP_PORT are optional now
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true

# Contact email settings
CONTACT_FROM="Ignite Contact YOUR_MAIL_ID"
CONTACT_TO=TO_THE_ID_YOU_WANT
