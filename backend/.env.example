NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/ignite
JWT_ADMIN_SECRET=your_strong_admin_secret_here
JWT_USER_SECRET=your_strong_user_secret_here

# Gmail SMTP settings (using app password)
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# Optional: leave unset to use Gmail defaults
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true

# Contact email settings
CONTACT_FROM="Ignite Contact your_email@gmail.com"
CONTACT_TO=recipient@example.com
